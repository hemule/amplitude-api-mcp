{
  "name": "amplitude-api-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Amplitude Analytics REST API (Taxonomy, Annotations, Releases)",
  "type": "module",
  "bin": {
    "amplitude-api-mcp": "cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "cli.js"
  ],
  "scripts": {
    "build": "esbuild --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js src/index.ts",
    "prepare": "npm run build",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.23.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
