# =============================================================================
# amplitude-api-mcp — environment
# =============================================================================
# Amplitude API key + secret key for ONE project.
# Find them in Amplitude: Settings → Projects → <your project> → General.
# Auth is HTTP Basic (api_key:secret_key), base64-encoded by the server.

AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=

# Data residency region: "us" (default) or "eu".
# Selects the API base URL automatically. Override with AMPLITUDE_BASE_URL if needed.
AMPLITUDE_REGION=us

# Optional: full base URL override (takes precedence over AMPLITUDE_REGION).
# AMPLITUDE_BASE_URL=https://amplitude.com

# -----------------------------------------------------------------------------
# Scaling to multiple projects (not needed for a single project):
# run a SECOND server instance in your MCP client config with its own
# AMPLITUDE_API_KEY / AMPLITUDE_SECRET_KEY. No code changes required.
# -----------------------------------------------------------------------------
